// src/services/api.js
import axios from 'axios';

// Aqui você cria uma instância configurada do Axios
export const api = axios.create({
  // URL base onde o Laravel do Miguel está rodando localmente
  baseURL: 'http://localhost:8000/api', 
  
  // Muito importante: diz ao Laravel que o React aceita cookies de sessão (Essencial para o login com Sanctum)
  withCredentials: true, 
  
  headers: {
    'Content-Type': 'application/json',
    'Accept': 'application/json',
  }
});

export default api;